# AWS Credentials for S3 ETL Pipeline
# DO NOT commit this file to git!

# Option 1: Environment Variables (Recommended)
# Set these in your system or .env file
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SESSION_TOKEN=your_session_token_here
AWS_REGION=us-west-2

# Option 2: AWS Credentials file (~/.aws/credentials)
# [default]
# aws_access_key_id = your_access_key_here
# aws_secret_access_key = your_secret_key_here
# aws_session_token = your_session_token_here

# S3 Bucket Configuration
S3_BUCKET_NAME=your-bucket-name

# Airflow orchestration
# auto = use S3 when AWS credentials and bucket are present, otherwise local
AIRFLOW_ETL_MODE=auto

# Cron schedule for the Airflow DAG
AIRFLOW_ETL_SCHEDULE=*/10 * * * *

# Local ETL output base inside the Airflow container or on host
ETL_LOCAL_BASE_DIR=/opt/airflow/project/data/etl_output
