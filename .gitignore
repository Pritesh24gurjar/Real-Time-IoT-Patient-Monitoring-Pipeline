# Large CSV data files in data directory
data/*.csv

# WISDM dataset directories (large files)
data/wisdm-dataset/
data/wisdm-dataset-organized/

# S3 mock data (local testing)
data/s3_mock/

# ETL output data (local testing)
data/etl_output/

# S3 ETL output (production testing)
data/s3_etl_output/


# Python cache
__pycache__/
data/__pycache__/
scripts/__pycache__/
*.py[cod]
*$py.class
*.so

# Jupyter notebooks (often contain large outputs)
*.ipynb_checkpoints/

# Environment files
.env
.venv/
env/

# OS files
.DS_Store
Thumbs.db

# Keep documentation (explicitly include)
!*.md
data/*.md

logs/*